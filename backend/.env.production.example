#--------------------------------------------------------------------
# PRODUCTION Environment — copy to .env on the server and fill in values
#--------------------------------------------------------------------

CI_ENVIRONMENT = production

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------

app.baseURL = 'https://admin.itanagarchoice.com/'
app.indexPage = ''
app.uriProtocol = PATH_INFO

#--------------------------------------------------------------------
# DATABASE
#--------------------------------------------------------------------

database.default.hostname = localhost
database.default.database = YOUR_CPANEL_DB_NAME
database.default.username = YOUR_CPANEL_DB_USER
database.default.password = YOUR_CPANEL_DB_PASSWORD
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port     = 3306

#--------------------------------------------------------------------
# SESSION
#--------------------------------------------------------------------

# session.savePath = /home/YOUR_USERNAME/tmp/sessions

