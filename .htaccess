Options +FollowSymLinks -Indexes
DirectoryIndex index.php
RewriteEngine on
RewriteBase /itanagar/

# ── 1. Serve real files directly (PHP, images, fonts, etc.) ──────────────────
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# ── 1b. Pass requests under public/ to public/.htaccess (local dev) ───────────
RewriteCond %{REQUEST_URI} ^/itanagar/public
RewriteRule ^ - [L]

# ── 2. React built assets (Vite base = /ui/, files live in public/ui/) ─────────
#       /ui/assets/* → serve from public/ui/assets/* (no need to hit CI4)
RewriteRule ^ui/assets/(.*)$ public/ui/assets/$1 [L]

# ── 3. /ci/* → CI4 admin (strips the ci/ prefix; CI4 sees /login, /web, etc.) ─
RewriteRule ^ci/?(.*) public/index.php/$1 [L,QSA]

# ── 4. Everything else → CI4 (ReactApp catch-all serves the React SPA) ────────
RewriteRule ^(.*)$ public/index.php/$1 [L,QSA]

# One month for most static assets
<filesMatch ".(css|jpg|jpeg|png|gif|js|ico)$">
Header set Cache-Control "max-age=2628000, public"
</filesMatch>

# php -- BEGIN cPanel-generated handler, do not edit
# Set the “ea-php82” package as the default “PHP” programming language.
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php82___lsphp .php .php8 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit
